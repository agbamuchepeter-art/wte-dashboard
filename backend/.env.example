# Copy this file to .env and fill in your values

# Absolute path to the cleaned waste CSV
DATA_PATH=10x-analyst-master/output/cleaned-data/cleaned_waste_output.csv

# Energy market price (EUR per MWh)
ELECTRICITY_PRICE_EUR_MWH=145.0

# Alert threshold: efficiency below this % triggers a warning
EFFICIENCY_THRESHOLD=65.0

# Live data refresh interval (seconds) — how fast WS pushes updates
LIVE_REFRESH_SECONDS=5

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# App metadata
APP_NAME=WTE Rotterdam Dashboard
APP_VERSION=1.0.0
